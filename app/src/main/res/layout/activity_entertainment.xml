<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:padding="16dp">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Title -->
        <TextView
            android:id="@+id/titleText"
            android:text="@string/entertainment_center_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Display jokes or facts -->
        <TextView
            android:id="@+id/resultText"
            android:text="@string/entertainment_center_prompt"
            android:textSize="18sp"
            android:gravity="center"
            android:textColor="#444"
            android:background="@drawable/result_box"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp" />

        <!-- Buttons for jokes and facts -->
        <Button
            android:id="@+id/jokeBtn"
            android:text="@string/tell_me_a_joke"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/factBtn"
            android:text="@string/give_me_a_fact"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" />

        <!-- Music controls -->
        <Button
            android:id="@+id/playMusicBtn"
            android:text="@string/play_relaxing_music"
            android:backgroundTint="#9C27B0"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/stopMusicBtn"
            android:text="@string/stop_music"
            android:backgroundTint="#E91E63"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" />

        <!-- Back button -->
        <Button
            android:id="@+id/backBtn"
            android:text="@string/back_to_main_menu"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>
</ScrollView>
