<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5EEDC"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Back Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/backBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="← Back to Main Menu"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#0D1B2A"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            app:backgroundTint="#D6ECFF" />

        <!-- Title -->
        <TextView
            android:id="@+id/dateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daily Check-In 📅"
            android:gravity="center"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#4B4B4B"
            android:layout_marginBottom="18dp" />

        <!-- Status Dropdown -->
        <Spinner
            android:id="@+id/statusSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:padding="10dp"
            android:background="#FFFFFF" />

        <!-- Check-In Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/checkInButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit Check-In"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#1B5E20"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            app:backgroundTint="#A8E6A3" />

        <!-- Status Display Message -->
        <TextView
            android:id="@+id/statusMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your daily status will appear here."
            android:textColor="@color/black"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginBottom="18dp" />

        <!-- White container for check-in history -->
        <LinearLayout
            android:id="@+id/checkinContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <ListView
                android:id="@+id/checkinList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@android:color/transparent"
                android:dividerHeight="10dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
